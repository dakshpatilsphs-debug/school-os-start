    const details = documentOptions.map((doc: string) => ({
      name: doc,
      submitted: submitted.includes(doc),
      status: submitted.includes(doc) ? 'Submitted' : 'Missing',
    }));
    const submittedCount = details.filter(doc => doc.submitted).length;
